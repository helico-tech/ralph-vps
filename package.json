{
  "name": "ralph",
  "version": "2.0.0",
  "type": "module",
  "bin": {
    "ralph": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test src/domain src/adapters src/cli",
    "test:integration": "bun test src/__tests__/integration",
    "docker:up": "docker compose -f docker-compose.test.yml up -d --build",
    "docker:down": "docker compose -f docker-compose.test.yml down -v"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4"
  }
}
